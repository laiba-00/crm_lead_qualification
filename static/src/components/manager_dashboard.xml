<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="crm_lead_qualification.ManagerDashboard">
        <div class="o_crm_dashboard">

            <!-- Loading Spinner -->
            <div t-if="state.loading" class="o_dashboard_loading">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p>Loading Dashboard...</p>
            </div>

            <div t-else="">

                <!-- Header -->
                <div class="o_dashboard_header">
                    <h2>Manager Dashboard</h2>
                    <button class="btn btn-primary btn-sm"
                            t-on-click="refreshDashboard">
                        ↻ Refresh
                    </button>
                </div>

                <!-- KPI CARDS -->
                <div class="o_kpi_row">

                    <div class="o_kpi_card o_kpi_blue">
                        <div class="o_kpi_icon">📋</div>
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.total_leads"/>
                        </div>
                        <div class="o_kpi_label">Active Cold Leads</div>
                    </div>

                    <div class="o_kpi_card o_kpi_orange">
                        <div class="o_kpi_icon">🔥</div>
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.total_hot_leads"/>
                        </div>
                        <div class="o_kpi_label">Hot Leads Generated</div>
                    </div>

                    <div class="o_kpi_card o_kpi_green">
                        <div class="o_kpi_icon">✅</div>
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.total_won"/>
                        </div>
                        <div class="o_kpi_label">Won Deals</div>
                    </div>

                    <div class="o_kpi_card o_kpi_red">
                        <div class="o_kpi_icon">❌</div>
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.total_lost"/>
                        </div>
                        <div class="o_kpi_label">Lost Deals</div>
                    </div>

                    <div class="o_kpi_card o_kpi_purple">
                        <div class="o_kpi_icon">📈</div>
                        <div class="o_kpi_value">
                            <t t-esc="state.kpis.conversion_rate"/>%
                        </div>
                        <div class="o_kpi_label">Conversion Rate</div>
                    </div>

                </div>

                <!-- PIPELINE CHART + CLOSER PERFORMANCE -->
                <div class="o_dashboard_row">

                    <!-- Pipeline Stage Chart -->
                    <div class="o_dashboard_card o_chart_card">
                        <h5 class="o_card_title">Pipeline Overview</h5>
                        <div class="o_chart_container">
                            <canvas id="pipelineChart"/>
                        </div>
                    </div>

                    <!-- Closer Performance -->
                    <div class="o_dashboard_card o_closer_card">
                        <h5 class="o_card_title">Closing Team Performance</h5>
                        <div t-if="!state.closer_performance.length"
                             class="o_no_data">
                            No data yet
                        </div>
                        <table t-else="" class="o_dashboard_table">
                            <thead>
                                <tr>
                                    <th>Closer</th>
                                    <th>Received</th>
                                    <th>Won</th>
                                    <th>Lost</th>
                                    <th>Pending</th>
                                    <th>Win Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="state.closer_performance"
                                    t-as="closer"
                                    t-key="closer.name">
                                    <td>
                                        <span class="o_agent_badge">
                                            <t t-esc="closer.name[0]"/>
                                        </span>
                                        <t t-esc="closer.name"/>
                                    </td>
                                    <td><t t-esc="closer.received"/></td>
                                    <td class="o_won_text">
                                        <t t-esc="closer.won"/>
                                    </td>
                                    <td class="o_lost_text">
                                        <t t-esc="closer.lost"/>
                                    </td>
                                    <td><t t-esc="closer.pending"/></td>
                                    <td>
                                        <span class="o_rate_badge"
                                              t-attf-class="o_rate_badge
                                              {{ closer.win_rate >= 50 ?
                                              'o_rate_good' : 'o_rate_low' }}">
                                            <t t-esc="closer.win_rate"/>%
                                        </span>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                </div>

                <!-- AGENT PERFORMANCE TABLE -->
                <div class="o_dashboard_card o_agent_card">
                    <h5 class="o_card_title">Agent Performance</h5>
                    <div t-if="!state.agent_performance.length"
                         class="o_no_data">
                        No agents assigned yet
                    </div>
                    <table t-else="" class="o_dashboard_table">
                        <thead>
                            <tr>
                                <th>Agent</th>
                                <th>Active Leads</th>
                                <th>Hot Leads</th>
                                <th>Won</th>
                                <th>Lost</th>
                                <th>Conversion Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="state.agent_performance"
                                t-as="agent"
                                t-key="agent.name">
                                <td>
                                    <span class="o_agent_badge">
                                        <t t-esc="agent.name[0]"/>
                                    </span>
                                    <t t-esc="agent.name"/>
                                </td>
                                <td><t t-esc="agent.assigned"/></td>
                                <td>
                                    <span class="o_hot_badge">
                                        🔥 <t t-esc="agent.hot_leads"/>
                                    </span>
                                </td>
                                <td class="o_won_text">
                                    <t t-esc="agent.won"/>
                                </td>
                                <td class="o_lost_text">
                                    <t t-esc="agent.lost"/>
                                </td>
                                <td>
                                    <div class="o_progress_bar">
                                        <div class="o_progress_fill"
                                             t-attf-style="width: {{ agent.conversion_rate }}%"/>
                                    </div>
                                    <span><t t-esc="agent.conversion_rate"/>%</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>
        </div>
    </t>

</templates>